{
  "name": "@igorjs/ward-sdk",
  "version": "0.1.0",
  "description": "TypeScript client for the ward sandbox daemon (gRPC over Unix socket)",
  "license": "Apache-2.0",
  "author": "Igor Santos <oss@mail.igorjs.io>",
  "homepage": "https://github.com/igorjs/ward",
  "repository": {
    "type": "git",
    "url": "https://github.com/igorjs/ward.git",
    "directory": "sdks/typescript"
  },
  "bugs": "https://github.com/igorjs/ward/issues",
  "keywords": ["ward", "sandbox", "microvm", "isolation", "ai-agent", "grpc"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src", "README.md", "LICENSE"],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "proto:generate": "grpc_tools_node_protoc --js_out=import_style=commonjs,binary:src/proto --grpc_out=grpc_js:src/proto --proto_path=../../proto ../../proto/ward.proto",
    "test": "node --test --experimental-test-module-mocks dist/*.test.js",
    "lint": "eslint src",
    "format": "prettier --write src"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.12.0",
    "google-protobuf": "^3.21.4"
  },
  "devDependencies": {
    "@types/google-protobuf": "^3.15.12",
    "@types/node": "^22",
    "grpc-tools": "^1.13.0",
    "grpc_tools_node_protoc_ts": "^5.3.3",
    "typescript": "^5.6.0",
    "eslint": "^9",
    "prettier": "^3"
  }
}
